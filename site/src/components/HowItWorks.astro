---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { title: t.step1Title, desc: t.step1Desc, output: t.step1Output, color: 'var(--purple)' },
  { title: t.step2Title, desc: t.step2Desc, output: t.step2Output, color: 'var(--accent-light)' },
  { title: t.step3Title, desc: t.step3Desc, output: t.step3Output, color: 'var(--success-light)' },
  { title: t.step4Title, desc: t.step4Desc, output: t.step4Output, color: 'var(--warning-light, #eab308)' },
];
---

<section class="section how" id="how">
  <div class="container">
    <h2 class="section-title fade-in">{t.howTitle}</h2>
    <p class="section-subtitle fade-in delay-1">{t.howSubtitle}</p>

    <!-- Visual Pipeline Diagram -->
    <div class="pipeline-wrapper fade-in delay-2">
      <div class="pipeline-nodes">
        {steps.map((step, i) => (
          <div class="pipeline-item" style={`--sc: ${step.color}`}>
            <div class="pipeline-node">
              <span class="node-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="node-name">{step.title}</span>
            </div>
            {i < steps.length - 1 && (
              <svg class="node-arrow" width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
                <path d="M0 6h16M12 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Step Cards -->
    <div class="steps-grid">
      {steps.map((step, i) => (
        <div class={`step-card fade-in delay-${i + 2}`} style={`--sc: ${step.color}`}>
          <div class="step-card-header">
            <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
            <code class="step-name">{step.title}</code>
          </div>
          <p class="step-desc">{step.desc}</p>
          <div class="step-output">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            <span>{step.output}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="how-footnote fade-in delay-5">{t.howFootnote}</p>
  </div>
</section>

<style>
  .how {
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }

  /* Pipeline Wrapper */
  .pipeline-wrapper {
    margin-bottom: 48px;
    padding: 28px 24px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow-x: auto;
  }

  /* Nodes Row */
  .pipeline-nodes {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .pipeline-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .pipeline-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 14px 24px;
    border-radius: var(--radius-md);
    border: 1px solid var(--accent-glow-strong);
    background: var(--accent-glow);
    transition: all 0.2s;
    min-width: 110px;
  }
  .pipeline-node:hover {
    border-color: var(--accent-light);
    background: var(--accent-glow-strong);
  }

  .node-num {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--sc);
    opacity: 0.5;
  }

  .node-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .node-arrow {
    flex-shrink: 0;
    color: var(--text-muted);
    opacity: 0.3;
  }

  /* Step Cards Grid */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .step-card {
    padding: 28px;
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    transition: border-color 0.2s;
    display: flex;
    flex-direction: column;
  }
  .step-card:hover {
    border-color: var(--border-light);
  }

  .step-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--sc);
    opacity: 0.7;
  }

  .step-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    background: var(--accent-glow);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .step-output {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--sc);
    font-family: var(--font-mono);
    line-height: 1.4;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .step-output svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--sc);
    opacity: 0.6;
  }

  .how-footnote {
    text-align: center;
    margin-top: 32px;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  @media (max-width: 768px) {
    .pipeline-wrapper {
      padding: 16px 12px;
    }

    .pipeline-nodes {
      display: flex !important;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: center;
    }

    .pipeline-item {
      gap: 6px;
    }

    .pipeline-node {
      min-width: unset;
      padding: 8px 14px;
      flex-direction: row;
      gap: 6px;
    }

    .node-num {
      display: none;
    }

    .node-name {
      font-size: 0.72rem;
    }

    .node-arrow {
      width: 14px;
      height: 9px;
    }

    .steps-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
