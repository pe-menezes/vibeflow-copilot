---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-badge fade-in">vibeflow</div>
    <h1 class="hero-title fade-in delay-1" set:html={t.heroTitle.replace('\n', '<br />')} />
    <p class="hero-subtitle fade-in delay-2">{t.heroSubtitle}</p>
    <p class="hero-desc fade-in delay-3">{t.heroDescription}</p>

    <div class="hero-quickstart fade-in delay-3">
      <div class="qs-header">
        <span class="qs-dot red"></span>
        <span class="qs-dot yellow"></span>
        <span class="qs-dot green"></span>
        <span class="qs-title">{t.heroQuickStartTitle}</span>
      </div>
      <div class="qs-body">
        <div class="qs-line">
          <span class="qs-cmd">{t.heroQuickStart1Cmd}</span>
          <span class="qs-arrow">&rarr;</span>
          <span class="qs-desc">{t.heroQuickStart1Desc}</span>
        </div>
        <div class="qs-line">
          <span class="qs-cmd">{t.heroQuickStart2Cmd}</span>
          <span class="qs-arrow">&rarr;</span>
          <span class="qs-desc">{t.heroQuickStart2Desc}</span>
        </div>
        <div class="qs-line">
          <span class="qs-cmd">{t.heroQuickStart3Cmd}</span>
          <span class="qs-arrow">&rarr;</span>
          <span class="qs-desc">{t.heroQuickStart3Desc}</span>
        </div>
        <div class="qs-line qs-line-pass">
          <span class="qs-cmd">{t.heroQuickStart4Cmd}</span>
          <span class="qs-arrow">&rarr;</span>
          <span class="qs-desc qs-pass">{t.heroQuickStart4Desc}</span>
        </div>
      </div>
    </div>

    <div class="hero-actions fade-in delay-4">
      <a href="#how" class="btn btn-primary">{t.heroCta}</a>
      <a href="#editions" class="btn btn-secondary">{t.heroInstall}</a>
    </div>
    <div class="hero-glow"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 160px 0 var(--section-gap);
    text-align: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 999px;
    border: 1px solid var(--accent);
    background: var(--accent-glow);
    color: var(--accent-light);
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin-bottom: 16px;
    background: linear-gradient(to bottom right, var(--text-primary), var(--text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
    margin-bottom: 20px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .hero-desc {
    max-width: 580px;
    margin: 0 auto 32px;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  /* Quick Start terminal block */
  .hero-quickstart {
    max-width: 580px;
    margin: 0 auto 40px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
    text-align: left;
    overflow: hidden;
  }

  .qs-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-inset);
  }

  .qs-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .qs-dot.red { background: #ef4444; }
  .qs-dot.yellow { background: #eab308; }
  .qs-dot.green { background: #22c55e; }

  .qs-title {
    margin-left: 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .qs-body {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qs-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .qs-cmd {
    color: var(--accent-light);
    font-weight: 600;
    white-space: nowrap;
    min-width: 160px;
  }

  .qs-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .qs-desc {
    color: var(--text-secondary);
  }

  .qs-pass {
    color: var(--success-light, #22c55e);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }
  .btn-primary:hover {
    background: var(--accent-light);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 24px var(--accent-glow-strong);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover {
    background: var(--bg-card-hover);
    color: var(--text-primary);
    border-color: var(--border-light);
    transform: translateY(-1px);
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, var(--accent-glow-strong) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 80px;
    }
    .hero-title {
      font-size: 2.25rem;
    }
    .hero-subtitle {
      font-size: 1.1rem;
    }
    .hero-desc {
      font-size: 0.95rem;
    }
    .qs-line {
      flex-wrap: wrap;
      gap: 4px;
    }
    .qs-cmd {
      min-width: auto;
    }
    .qs-arrow {
      display: none;
    }
    .qs-desc {
      font-size: 0.8rem;
      padding-left: 0;
    }
  }
</style>
