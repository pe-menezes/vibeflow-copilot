---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import LiveDemo from '../../components/LiveDemo.astro';
import UseCases from '../../components/UseCases.astro';
import Features from '../../components/Features.astro';
import Editions from '../../components/Editions.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Vibeflow | Desenvolvimento spec-driven para agentes de IA"
  description="Defina o que construir, deixe o agente de IA construir certo. Vibeflow separa o pensar do codar com specs, guardrails e auditorias."
  lang="pt-BR"
>
  <Header lang="pt-br" />
  <main>
    <Hero lang="pt-br" />
    <HowItWorks lang="pt-br" />
    <LiveDemo lang="pt-br" />
    <UseCases lang="pt-br" />
    <Features lang="pt-br" />
    <Editions lang="pt-br" />
    <FinalCTA lang="pt-br" />
    <ContactForm lang="pt-br" />
  </main>
  <Footer lang="pt-br" />
</Layout>
