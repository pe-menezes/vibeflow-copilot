---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import LiveDemo from '../../components/LiveDemo.astro';
import UseCases from '../../components/UseCases.astro';
import Features from '../../components/Features.astro';
import Editions from '../../components/Editions.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Vibeflow | Spec-driven development for AI agents"
  description="Define what to build, let the AI agent build it right. Vibeflow separates thinking from coding with specs, guardrails, and audits."
  lang="en"
>
  <Header lang="en" />
  <main>
    <Hero lang="en" />
    <HowItWorks lang="en" />
    <LiveDemo lang="en" />
    <UseCases lang="en" />
    <Features lang="en" />
    <Editions lang="en" />
    <FinalCTA lang="en" />
    <ContactForm lang="en" />
  </main>
  <Footer lang="en" />
</Layout>
